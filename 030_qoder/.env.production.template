# MetaEgg 本番環境設定
NODE_ENV=production
PORT=3001
LOG_LEVEL=warn

# データベース設定
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=metaegg_production
DB_USER=metaegg_user
DB_PASSWORD=your-secure-password

# Redis設定（キャッシュ）
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# セキュリティ設定
SESSION_SECRET=your-session-secret-key-must-be-32-chars-minimum
JWT_SECRET=your-jwt-secret-key-must-be-32-chars-minimum

# 外部API設定
YAHOO_API_KEY=your-yahoo-api-key
IRBANK_API_KEY=your-irbank-api-key

# 監視・ログ設定
SENTRY_DSN=your-sentry-dsn
ENABLE_METRICS=true

# パフォーマンス設定
MAX_CONCURRENCY=20
OPTIMIZATION_LEVEL=maximum
ENABLE_CACHE=true
ENABLE_OPTIMIZATION=true

# WebSocket設定
WS_PING_TIMEOUT=60000
WS_PING_INTERVAL=25000

# ファイルアップロード設定
UPLOAD_MAX_SIZE=10485760  # 10MB
UPLOAD_TIMEOUT=60000

# API制限設定
RATE_LIMIT_WINDOW=900000  # 15分
RATE_LIMIT_MAX=1000       # 最大リクエスト数