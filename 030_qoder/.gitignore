# MetaEgg システム - GitHub用 .gitignore

# ===========================================
# Node.js 関連
# ===========================================

# 依存関係
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# パッケージマネージャロックファイル（プロジェクトで使用しているもの以外）
# package-lock.jsonは含める（npmを使用）
yarn.lock
pnpm-lock.yaml

# npm キャッシュ
.npm
.eslintcache

# Optional npm cache directory
.npm-cache

# ===========================================
# TypeScript 関連
# ===========================================

# TypeScript ビルド出力
dist/
build/
*.tsbuildinfo
.tsbuildinfo

# TypeScript 宣言ファイル（自動生成）
*.d.ts.map

# scriptsディレクトリのコンパイル済みファイル
scripts/*.js
scripts/*.d.ts
scripts/*.d.ts.map

# ===========================================
# 開発・ビルドツール関連
# ===========================================

# Jest テストカバレッジ
coverage/
.nyc_output/

# ESLint キャッシュ
.eslintcache

# Prettier キャッシュ
.prettiercache

# ===========================================
# 環境設定・設定ファイル
# ===========================================

# 環境変数ファイル
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 設定ファイル（機密情報含む）
config/local.json
config/development.json
config/production.json
.config

# ===========================================
# データベース・キャッシュ関連
# ===========================================

# SQLite データベースファイル
*.sqlite
*.sqlite3
*.db

# Redis ダンプファイル
dump.rdb

# データベース移行・シードファイル（機密情報含む場合）
# migrations/
# seeds/

# ===========================================
# ログファイル
# ===========================================

# ログディレクトリ・ファイル
logs/
*.log
log/

# PM2 ログ
pids/
*.pid
*.seed
*.pid.lock

# ===========================================
# 一時ファイル・キャッシュ
# ===========================================

# 一時ディレクトリ
tmp/
temp/
.tmp/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ===========================================
# IDE・エディタ関連
# ===========================================

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ===========================================
# プロジェクト固有のデータファイル
# ===========================================

# MetaEgg データディレクトリ（機密性の高いファイル）
# data/の一部は除外、必要なものは個別に追加
data/_local/
data/cache/
data/temp/
data/private/
data/output/

# 処理済みデータファイル（大容量）
data/**/*.processed.csv
data/**/*.enriched.csv
data/**/*.final.csv
data/**/*.unified.csv
data/**/*.report.csv

# 外部取得データ（再取得可能）
data/**/*_raw.csv
data/**/*_downloaded.csv
data/input/downloaded/

# バックアップファイル
*.backup
*.bak

# ===========================================
# 成果物・レポート（大容量ファイル）
# ===========================================

# 生成されたレポート（サイズが大きい場合）
reports/generated/
reports/output/
*.report.html
*.report.pdf

# 最適化結果ファイル
optimization/results/
benchmarks/results/

# ===========================================
# セキュリティ・認証関連
# ===========================================

# 証明書・キーファイル
*.pem
*.key
*.crt
*.cert

# APIキー・トークンファイル
secrets/
.secrets
api-keys.json

# ===========================================
# Docker関連
# ===========================================

# Docker
.dockerignore
docker-compose.override.yml

# ===========================================
# CI/CD関連
# ===========================================

# GitHub Actions（必要なものは個別に追加）
# .github/workflows/

# その他CI/CDツールのキャッシュ
.circleci/
.travis.yml
.gitlab-ci.yml

# ===========================================
# パッケージング・デプロイ関連
# ===========================================

# アーカイブファイル
*.tar.gz
*.zip
*.rar

# デプロイメント設定（機密情報含む場合）
deploy/
deployment/
.deploy/

# ===========================================
# モニタリング・プロファイリング
# ===========================================

# パフォーマンス解析結果
*.cpuprofile
*.heapprofile
*.heapsnapshot

# モニタリングデータ
monitoring/data/
metrics/

# ===========================================
# 実験・テスト用ファイル
# ===========================================

# 実験用スクリプト・データ
experiments/
playground/
sandbox/

# テスト用一時ファイル
test-output/
test-results/
test-data/temp/

# ===========================================
# プロジェクト固有の除外項目
# ===========================================

# Qoder IDE 固有のファイル（必要なものは個別に追加）
.qoder/cache/
.qoder/logs/
.qoder/temp/
.qoder/workspace-state/
# .qoder/quests/ はプロジェクトの一部なので含める

# スクリプト実行結果
scripts/output/
scripts/logs/
scripts/results/

# 最適化設定の実行結果
optimization/cache/results/
optimization/logs/

# 外部データソースからの生データ（再取得可能）
fetchers/cache/
external-data/raw/

# ===========================================
# 特殊なファイル形式
# ===========================================

# バイナリファイル（特定の拡張子）
*.exe
*.dll
*.so
*.dylib

# メディアファイル（必要でない場合）
# 一時的なスクリーンショットやテスト用画像を除外
temp_*.png
temp_*.jpg
temp_*.jpeg
temp_*.gif
screenshot_*.png
test_*.png
*.tmp.png
*.tmp.jpg

# 動画ファイル（通常は不要）
*.mp4
*.mov
*.avi
*.mkv

# ただし、READMEや設計資料で使用する画像は含める
!docs/**/*.png
!docs/**/*.jpg
!docs/**/*.gif
!README-assets/*.png
!assets/**/*.png
!.github/**/*.png

# ===========================================
# 行末
# ===========================================